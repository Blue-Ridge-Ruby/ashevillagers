<div class="max-w-xl mx-auto px-4 py-12">
  <h1 class="text-3xl font-serif text-[#C0392B] mb-4">Create Your Profile</h1>
  <p class="text-gray-700 mb-8">
    We'll walk you through a few steps: upload a photo we can use as a reference, answer a handful of questions,
    and then pick a generated portrait. It only takes a few minutes.
  </p>

  <%= button_to "Start", profile_path, method: :post, class: "btn bg-[#2672B5] text-white hover:bg-[#3a6291]" %>
</div>
