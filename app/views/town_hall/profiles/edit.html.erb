<div class="max-w-sm mx-auto">
  <h1 class="text-2xl font-bold mb-6">Edit Profile</h1>

  <% if @steward.errors.any? %>
    <div class="mb-4 p-3 rounded bg-red-100 text-red-800">
      <ul>
        <% @steward.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @steward, url: town_hall_profile_path, method: :patch, class: "space-y-4" do |f| %>
    <fieldset class="fieldset">
      <legend class="fieldset-legend">First Name</legend>
      <%= f.text_field :first_name, required: true, class: "input" %>
    </fieldset>

    <fieldset class="fieldset">
      <legend class="fieldset-legend">Last Name</legend>
      <%= f.text_field :last_name, required: true, class: "input" %>
    </fieldset>

    <fieldset class="fieldset">
      <legend class="fieldset-legend">Email</legend>
      <%= f.email_field :email, required: true, class: "input" %>
    </fieldset>

    <fieldset class="fieldset">
      <legend class="fieldset-legend">Mobile Phone</legend>
      <%= f.phone_field :mobile_phone, class: "input" %>
    </fieldset>

    <hr class="border-gray-200">

    <p class="text-sm text-gray-500">Leave blank to keep your current password.</p>

    <fieldset class="fieldset">
      <legend class="fieldset-legend">New Password</legend>
      <%= f.password_field :password, class: "input" %>
    </fieldset>

    <fieldset class="fieldset">
      <legend class="fieldset-legend">Password Confirmation</legend>
      <%= f.password_field :password_confirmation, class: "input" %>
    </fieldset>

    <div class="flex gap-2">
      <%= f.submit "Save", class: "btn bg-indigo-600 text-white hover:bg-indigo-700" %>
    </div>
  <% end %>
</div>
