<div class="max-w-sm mx-auto">
  <h1 class="text-2xl font-bold mb-6">Set New Password</h1>

  <% if @steward.errors.any? %>
    <div class="mb-4 p-3 rounded bg-red-100 text-red-800">
      <ul>
        <% @steward.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with url: town_hall_password_reset_path(token: params[:token]), method: :patch, class: "space-y-4" do |f| %>
    <fieldset class="fieldset">
      <legend class="fieldset-legend">New Password</legend>
      <%= f.password_field :password, autofocus: true, required: true, class: "input w-full" %>
    </fieldset>

    <fieldset class="fieldset">
      <legend class="fieldset-legend">Password Confirmation</legend>
      <%= f.password_field :password_confirmation, required: true, class: "input w-full" %>
    </fieldset>

    <%= f.submit "Update password", class: "btn w-full bg-indigo-600 text-white hover:bg-indigo-700" %>
  <% end %>
</div>
