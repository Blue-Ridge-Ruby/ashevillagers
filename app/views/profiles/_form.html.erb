<% if profile.errors.any? %>
  <div class="mb-6 p-3 rounded bg-red-100 text-red-800">
    <ul>
      <% profile.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: profile, url: profile.persisted? ? profile_path : profile_path, method: profile.persisted? ? :patch : :post, class: "space-y-8" do |f| %>
  <div class="grid grid-cols-2 gap-4">
    <fieldset class="fieldset">
      <legend class="fieldset-legend">First Name</legend>
      <%= f.text_field :first_name, required: true, class: "input" %>
    </fieldset>
    <fieldset class="fieldset">
      <legend class="fieldset-legend">Last Name</legend>
      <%= f.text_field :last_name, required: true, class: "input" %>
    </fieldset>
  </div>

  <fieldset class="fieldset">
    <legend class="fieldset-legend">Profile Photo</legend>
    <div class="flex items-center gap-4">
      <div class="w-24 h-24 rounded bg-gray-100 flex items-center justify-center overflow-hidden shrink-0">
        <% if profile.photo.attached? && profile.photo.content_type.start_with?("image/") %>
          <%= image_tag profile.photo.variant(resize_to_fill: [200, 200]), class: "w-full h-full object-cover" %>
        <% else %>
          <svg class="w-12 h-12 text-gray-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/></svg>
        <% end %>
      </div>
      <%= f.file_field :photo, accept: "image/png,image/jpeg,image/webp,image/gif", class: "file-input" %>
    </div>
  </fieldset>

  <% if questions.any? %>
    <div>
      <h2 class="text-sm font-bold text-gray-900 mb-4">Answer <%= questions.size == 1 ? "a Question" : "#{questions.size} Questions" %></h2>
      <div class="space-y-2">
        <%= f.fields_for :profile_answers, profile.profile_answers.sort_by { |pa| questions.index { |q| q.id == pa.profile_question_id } || 999 } do |af| %>
          <% question = questions.detect { |q| q.id == af.object.profile_question_id } %>
          <% next unless question %>
          <fieldset class="fieldset">
            <legend class="fieldset-legend"><%= question.question %></legend>
            <%= af.hidden_field :profile_question_id %>
            <%= af.hidden_field :id if af.object.persisted? %>
            <%= af.text_field :answer, class: "input" %>
          </fieldset>
        <% end %>
      </div>
    </div>
  <% end %>

  <div>
    <h2 class="text-sm font-bold text-gray-900 mb-1">Add Sharing Links</h2>
    <p class="text-sm text-gray-500 mb-4">Enter any links you want to share on the <%= link_to "Ashevillagers", root_path, class: "underline" %> page.</p>
    <div class="space-y-2">
      <% [
        [:twitter_url, "X/Twitter", "https://x.com/yourhandle"],
        [:bluesky_url, "Bluesky", "https://bsky.app/profile/yourhandle"],
        [:mastodon_url, "Mastodon", "https://ruby.social/@yourhandle"],
        [:linkedin_url, "LinkedIn", "https://www.linkedin.com/in/yourhandle/"],
        [:website_url, "Website or Blog", "https://yoursite.com"],
      ].each do |attr, label, placeholder| %>
        <fieldset class="fieldset">
          <legend class="fieldset-legend"><%= label %></legend>
          <%= f.url_field attr, placeholder: placeholder, class: "input" %>
        </fieldset>
      <% end %>
    </div>
  </div>

  <div>
    <%= f.submit profile.persisted? ? "Save Profile" : "Create Profile", class: "btn bg-[#2672B5] text-white hover:bg-[#3a6291]" %>
  </div>
<% end %>
