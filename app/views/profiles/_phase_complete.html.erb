<%= turbo_stream_from profile %>

<div class="space-y-8">
  <div class="p-4 rounded bg-green-50 border border-green-200">
    <div class="flex items-center justify-between gap-4">
      <div>
        <div class="font-bold text-green-900">Your profile is live.</div>
        <div class="text-sm text-green-800">You can keep refining it below.</div>
      </div>
      <%= link_to "View public profile", public_profile_path(profile), class: "btn btn-sm bg-white border border-green-300 text-green-900" %>
    </div>
  </div>

  <%= form_with model: profile, url: profile_path, method: :patch, class: "space-y-8" do |f| %>
    <div>
      <h3 class="text-sm font-bold text-gray-900 mb-2">Your Portrait</h3>
      <div class="grid grid-cols-2 gap-3">
        <% profile.image_generations.includes(image_attachment: :blob).each do |ig| %>
          <%= render "image_generation", image_generation: ig, selected_id: profile.selected_image_generation_id %>
        <% end %>
      </div>
    </div>

    <div>
      <h3 class="text-sm font-bold text-gray-900 mb-2">Your Name</h3>
      <div class="grid grid-cols-2 gap-4">
        <fieldset class="fieldset">
          <legend class="fieldset-legend">First Name</legend>
          <%= f.text_field :first_name, required: true, class: "input" %>
        </fieldset>
        <fieldset class="fieldset">
          <legend class="fieldset-legend">Last Name</legend>
          <%= f.text_field :last_name, required: true, class: "input" %>
        </fieldset>
      </div>
    </div>

    <div>
      <h3 class="text-sm font-bold text-gray-900 mb-1">Sharing Links</h3>
      <div class="space-y-2">
        <% [
          [:twitter_url, "X/Twitter", "https://x.com/yourhandle"],
          [:bluesky_url, "Bluesky", "https://bsky.app/profile/yourhandle"],
          [:mastodon_url, "Mastodon", "https://ruby.social/@yourhandle"],
          [:linkedin_url, "LinkedIn", "https://www.linkedin.com/in/yourhandle/"],
          [:website_url, "Website or Blog", "https://yoursite.com"],
        ].each do |attr, label, placeholder| %>
          <fieldset class="fieldset">
            <legend class="fieldset-legend"><%= label %></legend>
            <%= f.url_field attr, placeholder: placeholder, class: "input" %>
          </fieldset>
        <% end %>
      </div>
    </div>

    <%= f.submit "Save Changes", class: "btn bg-[#2672B5] text-white hover:bg-[#3a6291]" %>
  <% end %>
</div>
