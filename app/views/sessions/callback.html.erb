<div class="max-w-sm mx-auto py-16 text-center">
  <h1 class="text-2xl font-bold mb-4">Signing you in&hellip;</h1>
  <noscript>
    <p class="text-gray-600 mb-8">Click the button below to sign in to your Ashevillagers profile.</p>
  </noscript>

  <%= form_with url: callback_session_path, method: :post, id: "login-callback", class: "inline" do |f| %>
    <%= f.hidden_field :token, value: @token %>
    <noscript>
      <%= f.submit "Sign in", class: "bg-[#2672B5] text-white py-2 px-6 rounded font-medium hover:bg-[#3a6291] cursor-pointer" %>
    </noscript>
  <% end %>
</div>

<script nonce="<%= request.content_security_policy_nonce %>">document.getElementById("login-callback").requestSubmit()</script>
