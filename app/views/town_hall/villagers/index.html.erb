<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold">Villagers</h1>
  <div class="flex gap-2">
    <%= button_to "Sync from Tito", sync_town_hall_villagers_path, method: :post,
          class: "bg-green-600 text-white py-2 px-4 rounded hover:bg-green-700 cursor-pointer" %>
    <%= link_to "Add villager", new_town_hall_villager_path, class: "bg-indigo-600 text-white py-2 px-4 rounded hover:bg-indigo-700" %>
  </div>
</div>

<table class="w-full bg-white rounded shadow">
  <thead class="bg-gray-100">
    <tr>
      <th class="text-left px-4 py-2">Name</th>
      <th class="text-left px-4 py-2">Email</th>
      <th class="text-left px-4 py-2">Tito</th>
      <th class="px-4 py-2"></th>
    </tr>
  </thead>
  <tbody>
    <% @villagers.each do |villager| %>
      <tr class="border-t">
        <td class="px-4 py-2"><%= [villager.first_name, villager.last_name].compact.join(" ") %></td>
        <td class="px-4 py-2"><%= villager.email %></td>
        <td class="px-4 py-2">
          <% if villager.admin_ticket_url %>
            <%= link_to "Ticket", villager.admin_ticket_url, target: "_blank", rel: "noopener noreferrer", class: "text-indigo-600 hover:underline" %>
          <% end %>
        </td>
        <td class="px-4 py-2 text-right space-x-2">
          <%= link_to "Edit", edit_town_hall_villager_path(villager), class: "text-indigo-600 hover:underline" %>
          <%= button_to "Delete", town_hall_villager_path(villager), method: :delete,
                data: { turbo_confirm: "Remove #{villager.first_name} #{villager.last_name}?" },
                class: "text-red-600 hover:underline bg-transparent border-0 cursor-pointer inline" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
