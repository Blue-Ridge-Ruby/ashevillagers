<% if profile_question.errors.any? %>
  <div class="mb-4 p-3 rounded bg-red-100 text-red-800">
    <ul>
      <% profile_question.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: profile_question, url: profile_question.persisted? ? town_hall_profile_question_path(profile_question) : town_hall_profile_questions_path, class: "space-y-4" do |f| %>
  <fieldset class="fieldset">
    <legend class="fieldset-legend">Question</legend>
    <%= f.text_area :question, required: true, rows: 2, class: "textarea w-full" %>
  </fieldset>

  <fieldset class="fieldset">
    <legend class="fieldset-legend">LLM Instructions</legend>
    <%= f.text_area :llm_prompt, rows: 8, class: "textarea w-full" %>
    <p class="label">Instructions sent to the LLM to generate a job title from the user's answer to this question.</p>
  </fieldset>

  <fieldset class="fieldset">
    <legend class="fieldset-legend">Position</legend>
    <%= f.number_field :position, class: "input w-24" %>
  </fieldset>

  <div class="flex items-center gap-2">
    <%= f.check_box :active, class: "checkbox" %>
    <%= f.label :active, "Active", class: "text-sm font-medium text-gray-700" %>
  </div>

  <div class="flex gap-2">
    <%= f.submit class: "btn bg-indigo-600 text-white hover:bg-indigo-700" %>
    <%= link_to "Cancel", town_hall_profile_questions_path, class: "btn btn-ghost" %>
  </div>
<% end %>
