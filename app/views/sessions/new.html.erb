<div class="max-w-sm mx-auto py-16">
  <h1 class="text-2xl font-bold mb-2 text-center">Sign In</h1>
  <p class="text-gray-600 text-center mb-8">Enter your email and we'll send you a login link.</p>

  <%= form_with url: session_path, method: :post, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :email, "Email address", class: "block text-sm font-medium text-gray-700" %>
      <%= f.email_field :email, required: true, autofocus: true, class: "mt-1 block w-full rounded border-gray-300 shadow-sm" %>
    </div>

    <div>
      <%= f.submit "Send login link", class: "w-full bg-[#2672B5] text-white py-2 px-4 rounded font-medium hover:bg-[#3a6291] cursor-pointer" %>
    </div>
  <% end %>
</div>
