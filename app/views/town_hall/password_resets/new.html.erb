<div class="max-w-sm mx-auto">
  <h1 class="text-2xl font-bold mb-6">Reset Password</h1>

  <p class="mb-4 text-sm text-gray-600">Enter your email and we'll send you a reset link.</p>

  <%= form_with url: town_hall_password_reset_path, method: :post, class: "space-y-4" do |f| %>
    <fieldset class="fieldset">
      <legend class="fieldset-legend">Email</legend>
      <%= f.email_field :email, autofocus: true, required: true, class: "input" %>
    </fieldset>

    <%= f.submit "Send reset link", class: "btn w-full bg-indigo-600 text-white hover:bg-indigo-700" %>
  <% end %>

  <p class="mt-4 text-sm text-center">
    <%= link_to "Back to sign in", new_town_hall_session_path, class: "text-indigo-600 hover:underline" %>
  </p>
</div>
