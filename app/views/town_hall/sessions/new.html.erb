<div class="max-w-sm mx-auto">
  <h1 class="text-2xl font-bold mb-6">Sign in to Town Hall</h1>

  <%= form_with url: town_hall_session_path, method: :post, class: "space-y-4" do |f| %>
    <fieldset class="fieldset">
      <legend class="fieldset-legend">Email</legend>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", required: true, class: "input w-full" %>
    </fieldset>

    <fieldset class="fieldset">
      <legend class="fieldset-legend">Password</legend>
      <%= f.password_field :password, autocomplete: "current-password", required: true, class: "input w-full" %>
    </fieldset>

    <%= f.submit "Sign in", class: "btn w-full bg-indigo-600 text-white hover:bg-indigo-700" %>
  <% end %>

  <p class="mt-4 text-sm text-center">
    <%= link_to "Forgot your password?", new_town_hall_password_reset_path, class: "text-indigo-600 hover:underline" %>
  </p>
</div>
