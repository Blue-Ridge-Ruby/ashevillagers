<% if profile_question.errors.any? %>
  <div class="mb-4 p-3 rounded bg-red-100 text-red-800">
    <ul>
      <% profile_question.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: profile_question, url: profile_question.persisted? ? town_hall_profile_question_path(profile_question) : town_hall_profile_questions_path, class: "space-y-4" do |f| %>
  <div>
    <%= f.label :question, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :question, required: true, rows: 2, class: "mt-1 block w-full rounded border-gray-300 shadow-sm" %>
  </div>

  <div>
    <%= f.label :llm_prompt, "LLM Prompt", class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :llm_prompt, rows: 8, class: "mt-1 block w-full rounded border-gray-300 shadow-sm" %>
    <p class="mt-1 text-xs text-gray-500">Prompt sent to the LLM when generating profile images for this question. Use <code class="font-mono">%s</code> to interpolate the name of the animal.</p>
  </div>

  <div>
    <%= f.label :position, class: "block text-sm font-medium text-gray-700" %>
    <%= f.number_field :position, class: "mt-1 block w-24 rounded border-gray-300 shadow-sm" %>
  </div>

  <div class="flex items-center gap-2">
    <%= f.check_box :active, class: "rounded border-gray-300" %>
    <%= f.label :active, "Active", class: "text-sm font-medium text-gray-700" %>
  </div>

  <div class="flex gap-2">
    <%= f.submit class: "bg-indigo-600 text-white py-2 px-4 rounded hover:bg-indigo-700 cursor-pointer" %>
    <%= link_to "Cancel", town_hall_profile_questions_path, class: "py-2 px-4 text-gray-600 hover:underline" %>
  </div>
<% end %>
