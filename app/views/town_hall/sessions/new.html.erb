<div class="max-w-sm mx-auto">
  <h1 class="text-2xl font-bold mb-6">Sign in to Town Hall</h1>

  <%= form_with url: town_hall_session_path, method: :post, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :email, class: "block text-sm font-medium text-gray-700" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", required: true, class: "mt-1 block w-full rounded border-gray-300 shadow-sm" %>
    </div>

    <div>
      <%= f.label :password, class: "block text-sm font-medium text-gray-700" %>
      <%= f.password_field :password, autocomplete: "current-password", required: true, class: "mt-1 block w-full rounded border-gray-300 shadow-sm" %>
    </div>

    <%= f.submit "Sign in", class: "w-full bg-indigo-600 text-white py-2 px-4 rounded hover:bg-indigo-700 cursor-pointer" %>
  <% end %>

  <p class="mt-4 text-sm text-center">
    <%= link_to "Forgot your password?", new_town_hall_password_reset_path, class: "text-indigo-600 hover:underline" %>
  </p>
</div>
