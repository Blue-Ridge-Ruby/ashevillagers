<%= tag.div id: dom_id(image_generation), class: "relative rounded border-8 overflow-hidden bg-gray-50", style: "border-color: #{image_generation.color.oklch_css}" do %>
  <% if image_generation.image.attached? %>
    <label class="block cursor-pointer">
      <%= image_tag rails_representation_path(image_generation.image.variant(resize_to_fill: [300, 400])), class: "w-full aspect-3/4 object-cover", alt: image_generation.title %>
      <div class="p-2 flex items-center gap-2 bg-white">
        <%= radio_button_tag "profile[selected_image_generation_id]", image_generation.id, local_assigns[:selected_id] == image_generation.id, class: "radio radio-sm" %>
        <span class="text-sm">Choose this</span>
      </div>
    </label>
  <% else %>
    <div class="w-full aspect-3/4 flex items-center justify-center bg-gray-100 animate-pulse">
      <div class="text-center">
        <div class="text-sm text-gray-500">Generating…</div>
        <div class="text-xs text-gray-400 mt-1">(~60s)</div>
      </div>
    </div>
    <div class="p-2 flex items-center gap-2 bg-white">
      <input type="radio" disabled class="radio radio-sm">
      <span class="text-sm text-gray-400">Choose this</span>
    </div>
  <% end %>
<% end %>
